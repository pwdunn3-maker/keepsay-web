{
  "routes": [
    { "src": "/logo-kheart.png", "dest": "/logo-kheart.png" },
    { "src": "/icon.png", "dest": "/icon.png" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/privacy/", "dest": "/privacy.html" },
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/legal/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/terms/", "dest": "/terms.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/legal/terms", "dest": "/terms.html" },
    { "src": "/memory", "dest": "/memory.html" },
    { "src": "/memory.html", "dest": "/memory.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/support/", "dest": "/support.html" },
    { "src": "/support.html", "dest": "/support.html" },
    { "src": "/(.*)\\.(jpg|jpeg|png|gif|svg|webp|ico|css|js|woff|woff2|ttf|otf|json|xml|txt)", "dest": "/$1.$2" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/holding.html" }
  ],
  "crons": [
    {
      "path": "/api/r2-backup",
      "schedule": "0 2 * * *"
    }
  ]
}