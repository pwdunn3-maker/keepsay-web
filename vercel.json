{
  "routes": [
    { "src": "/logo-kheart.png", "dest": "/logo-kheart.png" },
    { "src": "/icon.png", "dest": "/icon.png" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/privacy/", "dest": "/privacy.html" },
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/legal/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/terms/", "dest": "/terms.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/legal/terms", "dest": "/terms.html" },
    { "src": "/memory", "dest": "/memory.html" },
    { "src": "/memory.html", "dest": "/memory.html" },
    { "src": "/story", "dest": "/story.html" },
    { "src": "/story/", "dest": "/story.html" },
    { "src": "/story.html", "dest": "/story.html" },
    { "src": "/support", "dest": "/support.html" },
    { "src": "/support/", "dest": "/support.html" },
    { "src": "/support.html", "dest": "/support.html" },
    { "src": "/reset", "dest": "/reset.html" },
    { "src": "/reset/", "dest": "/reset.html" },
    { "src": "/reset.html", "dest": "/reset.html" },
    { "src": "/gift", "dest": "/gift.html" },
    { "src": "/gift/", "dest": "/gift.html" },
    { "src": "/gift.html", "dest": "/gift.html" },
    { "src": "/wedding-vault", "dest": "/wedding-vault.html" },
    { "src": "/wedding-vault/", "dest": "/wedding-vault.html" },
    { "src": "/wedding-vault.html", "dest": "/wedding-vault.html" },
    { "src": "/redeem", "dest": "/redeem.html" },
    { "src": "/redeem/", "dest": "/redeem.html" },
    { "src": "/redeem.html", "dest": "/redeem.html" },
    { "src": "/redeem/(.*)", "dest": "/redeem.html" },
    { "src": "/(.*)\\.(jpg|jpeg|png|gif|svg|webp|ico|css|js|woff|woff2|ttf|otf|json|xml|txt|m4a|mp3|mp4|m4v|mov|wav|ogg|webm|pdf)", "dest": "/$1.$2" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/invite/(.*)", "dest": "/invite.html" },
    { "src": "/vault/(.*)", "dest": "/vault/[token].html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/r2-backup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cleanup-vault-uploads",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/transcode-vault-media",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "api/transcode-vault-media.js": {
      "maxDuration": 300,
      "memory": 3008
    }
  }
}